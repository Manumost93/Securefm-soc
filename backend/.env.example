# ============================================================
# SecureFM SOC — Backend Environment Variables
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development

# JWT — OBLIGATORIO. Mínimo 32 caracteres. Cámbialo en producción.
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres_aleatorios
JWT_EXPIRES_IN=8h

# ------------------------------------------------------------
# BASE DE DATOS — PostgreSQL (recomendado, producción y Docker)
# Levanta PostgreSQL con: docker run -e POSTGRES_USER=sfm_user
#   -e POSTGRES_PASSWORD=sfm_password -e POSTGRES_DB=securefm_soc
#   -p 5432:5432 postgres:16-alpine
# O usa docker compose (ver docs/DOCKER.md - Fase 4)
# ------------------------------------------------------------
DATABASE_URL="postgresql://sfm_user:sfm_password@localhost:5432/securefm_soc?schema=public"

# Credenciales de PostgreSQL (usadas también en docker-compose)
POSTGRES_USER=sfm_user
POSTGRES_PASSWORD=sfm_password
POSTGRES_DB=securefm_soc
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------
# CORS — URL del frontend
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
