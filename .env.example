# ============================================================
# SecureFM SOC — Variables de entorno para Docker Compose
# Copia este archivo como .env en la raíz del proyecto
# ============================================================

# JWT — OBLIGATORIO. Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_minimo_32_chars
JWT_EXPIRES_IN=8h

# PostgreSQL
POSTGRES_USER=sfm_user
POSTGRES_PASSWORD=sfm_password
POSTGRES_DB=securefm_soc
POSTGRES_PORT=5432

# Puertos expuestos en el host
FRONTEND_PORT=80

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
